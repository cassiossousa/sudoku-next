{
  "name": "sudoku-next",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/cassiossousa/sudoku-next.git"
  },
  "homepage": "https://cassiossousa.github.io/sudoku-next/",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "prettier": "prettier --write .",
    "prettier-check": "prettier --check .",
    "start": "next start",
    "test": "jest --verbose",
    "test-cov": "jest --coverage",
    "test-watch": "jest --watch --coverage",
    "ts-prune": "npx knip --include exports,types,nsExports,nsTypes",
    "ts-unused-exports": "npx knip --include exports,types,nsExports,nsTypes",
    "tsc": "tsc --noEmit",
    "unimported": "npx knip --production --dependencies --files"
  },
  "dependencies": {
    "next": "16.2.1",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "14.3.1",
    "@types/jest": "30.0.0",
    "@types/node": "20.19.37",
    "@types/react": "18.3.28",
    "autoprefixer": "10.4.27",
    "eslint": "9.39.4",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "10.1.8",
    "jest": "29.7.0",
    "jest-environment-jsdom": "30.3.0",
    "jiti": "2.6.1",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "tailwindcss": "3.4.19",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0"
  }
}
